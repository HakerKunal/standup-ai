{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/generate", "dest": "api/index.py" },
    { "src": "/formats",  "dest": "api/index.py" },
    { "src": "/health",   "dest": "api/index.py" },
    { "src": "/(.*)",     "dest": "public/$1"    }
  ]
}
